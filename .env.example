# Copy to `.env` for local dev. In production these are set in the Vercel project
# environment (sourced from Bitwarden Secrets Manager). See README / deploy notes.

# DB — Postgres. For hosted providers append `?sslmode=require`.
POSTGRES_URL="postgres://postgres:mysecretpassword@localhost:5433/local"

# ENV / domain
# PUBLIC_ENV: development | preview | staging | production
PUBLIC_ENV=development
# Your production domain (no protocol), e.g. secrets.example.com
PUBLIC_PRODUCTION_URL='localhost:5173'
# Auto-provided by Vercel; only used when PUBLIC_ENV=preview.
VERCEL_URL='localhost:5173'

# Rate limiting (sveltekit-rate-limiter) — random secret
RATE_LIMIT_COOKIE_SECRET=''

# Email — Lettermint (https://lettermint.co)
LETTERMINT_TOKEN=''
# From address; the domain MUST be verified in your Lettermint project.
EMAIL_FROM='Acme <no-reply@acme.com>'

# Storage — Cloudflare R2 (S3-compatible)
# Endpoint host: <account_id>.r2.cloudflarestorage.com
PUBLIC_S3_ENDPOINT=''
# Bucket name (may be shared with other data — objects are namespaced by prefix below)
PUBLIC_S3_BUCKET=''
# Key prefix for all objects; the cron cleanup only ever lists/deletes within it.
PUBLIC_S3_KEY_PREFIX='scrt-link/'
S3_ACCESS_KEY=''
S3_SECRET_KEY=''

# Vercel cron auth — random secret; Vercel injects it for the scheduled cron.
CRON_SECRET=''

# E2E test credentials (GitHub Actions only)
E2E_USER_EMAIL=''
E2E_USER_PASSWORD=''
